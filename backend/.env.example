# Copy to backend/.env for local development
ENVIRONMENT=development
SECRET_KEY=xmeme-dev-secret-change-me-in-production
DATABASE_URL=sqlite:///./xmeme.db
UPLOAD_DIR=uploads
API_PUBLIC_URL=http://localhost:8081
FRONTEND_URL=http://localhost:8001
CORS_ORIGINS=http://localhost:8000,http://localhost:8001
TRUSTED_HOSTS=*
SEED_ON_STARTUP=true
ENABLE_DOCS=true
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ADMIN_USERNAMES=
GIPHY_API_KEY=
