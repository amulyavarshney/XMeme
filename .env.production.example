# Production environment template — copy to .env and fill in values
ENVIRONMENT=production
SECRET_KEY=replace-with-openssl-rand-hex-32
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql+psycopg2://xmeme:replace-with-strong-db-password@db:5432/xmeme
API_PUBLIC_URL=https://api.example.com
FRONTEND_URL=https://example.com
CORS_ORIGINS=https://example.com
TRUSTED_HOSTS=api.example.com,example.com
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_USERNAMES=your_admin_username
ENABLE_DOCS=false
SEED_ON_STARTUP=true
LOG_LEVEL=INFO
WEB_CONCURRENCY=2
XMEME_API_BASE=/api
GIPHY_API_KEY=
